{% extends 'base.html' %}

{% block header %}
  <h1>{% block title %}Search For Word{% endblock %}</h1>
{% endblock %}

{% block content %}
  <form method="post">
    <label for="word">Word</label>
    <input name="word" id="word" required>
    <input type="submit" value="Search Word">
  </form>
{% endblock %}